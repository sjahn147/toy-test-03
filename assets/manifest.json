{
  "version": 6,
  "mode": "procedural-modular-dungeon-faction-ecology",
  "notes": "Rooms, facilities, combat, equipment, species ecology, infections and territorial factions are generated from shared runtime contracts. Lairs, corpses, hosts, traps, attachments, infections, spawn omens and room ownership remain visible world entities.",
  "topology": {
    "builder": "src/engine/DungeonTopology.js",
    "connectionModel": "room-port to room-port",
    "movement": "continuous corridor and reserved-cell travel",
    "surfaceRule": "room floors and corridor floors share the same top-surface elevation"
  },
  "environment": {
    "factory": "src/engine/AssetRegistry.js",
    "activeAssets": [
      "room-floor-slab",
      "inset-room-floor",
      "segmented-wall",
      "door-frame",
      "door-threshold",
      "corridor-floor",
      "corridor-curbs",
      "entrance-waystation",
      "water-fountain",
      "rest-site",
      "camp-site",
      "merchant-stall",
      "goddess-statue"
    ]
  },
  "miniatures": {
    "recipes": "src/miniatures/recipes.js",
    "partCatalog": "src/miniatures/partCatalog.js",
    "factory": "src/engine/MiniatureFactory.js",
    "ecologyFactory": "src/engine/EcologyAssetFactory.js",
    "advancedEcologyFactory": "src/engine/AdvancedCreatureAssetFactory.js",
    "roles": [
      "fighter",
      "rogue",
      "cleric",
      "wizard",
      "archer",
      "goblin",
      "skeleton",
      "spider",
      "rat",
      "ogre",
      "slime",
      "mimic",
      "zombie",
      "orc",
      "myconid",
      "stirge",
      "carrion",
      "kobold",
      "wraith",
      "parasite"
    ],
    "sharedSockets": [
      "root",
      "pelvis",
      "chest",
      "head",
      "headTop",
      "handL",
      "handR",
      "shoulderL",
      "shoulderR",
      "back",
      "waistFront",
      "waistBack",
      "baseFx"
    ]
  },
  "combat": {
    "simulation": "src/sim/DungeonSimPhase3.js",
    "projectiles": "src/sim/ProjectileSystem.js",
    "renderer": "src/engine/DungeonRendererPhase3.js",
    "activeProjectiles": ["arrow", "magic", "heal", "web"]
  },
  "equipment": {
    "catalog": "src/data/itemCatalog.js",
    "system": "src/sim/EquipmentSystem.js",
    "simulation": "src/sim/DungeonSimPhase4.js",
    "assetFactory": "src/engine/EquipmentAssetFactory.js",
    "renderer": "src/engine/DungeonRendererPhase4.js",
    "slots": ["mainHand", "offHand", "head", "body", "accessory"],
    "features": [
      "role-aware automatic equipment comparison",
      "monster and treasure loot tables",
      "floor loot dioramas",
      "weapon and armor durability",
      "equipment break and repair",
      "merchant buy sell and repair",
      "live miniature socket replacement"
    ]
  },
  "ecology": {
    "scenarioDecorator": "src/data/applyPhase5Ecology.js",
    "system": "src/sim/EcosystemSystem.js",
    "simulation": "src/sim/DungeonSimPhase5.js",
    "assetFactory": "src/engine/EcologyAssetFactory.js",
    "renderer": "src/engine/DungeonRendererPhase5.js",
    "species": ["skeleton", "goblin", "spider", "slime", "rat", "ogre"],
    "lairs": ["ossuary_lair", "goblin_lair", "spider_lair", "slime_pool", "rat_warren", "ogre_lair"],
    "worldEntities": ["corpse", "living_host", "pending_spawn"],
    "features": [
      "species hunger and starvation",
      "intra-dungeon predation",
      "corpse biomass and bone resources",
      "spider host capture and transport",
      "resource-gated reproduction",
      "visible timed spawn omens",
      "lair footprint occupancy blocking"
    ]
  },
  "advancedEcology": {
    "scenarioDecorator": "src/data/applyPhase6Ecology.js",
    "config": "src/sim/advancedEcologyConfig.js",
    "system": "src/sim/AdvancedEcologySystem.js",
    "simulation": "src/sim/DungeonSimPhase6.js",
    "creatureFactory": "src/engine/AdvancedCreatureAssetFactory.js",
    "lairFactory": "src/engine/AdvancedLairAssetFactory.js",
    "registry": "src/engine/AssetRegistryPhase6.js",
    "renderer": "src/engine/DungeonRendererPhase6.js",
    "species": ["zombie", "orc", "myconid", "stirge", "carrion", "kobold", "wraith", "parasite"],
    "lairs": ["plague_mortuary", "orc_tribe_camp", "fungal_garden", "blood_roost", "carrion_pit", "kobold_workshop", "cursed_chapel", "parasite_pool"],
    "factions": ["undead-host", "red-tusk-tribe", "goblin-clan", "copper-tail-clutch", "bluecap-colony", "red-wing-brood", "carrion-brood", "pale-brood", "slime-bloom", "ogre-solitary", "warren-vermin"],
    "worldEntities": ["territory", "faction_trap", "stirge_attachment", "parasite_infection", "advanced_pending_spawn"],
    "features": [
      "cross-species corpse competition",
      "zombie corpse recruitment",
      "myconid decomposition and sleep spores",
      "stirge blood attachment",
      "parasite infection and larval emergence",
      "kobold manufactured traps",
      "wraith death-energy harvesting",
      "orc predation and territorial expansion",
      "cross-faction room combat",
      "visible room capture and contested borders"
    ]
  },
  "effects": {
    "active": [
      "attack",
      "death",
      "gold",
      "heal",
      "arrow-impact",
      "magic-impact",
      "web-impact",
      "downed",
      "equipment-upgrade",
      "equipment-break",
      "feeding",
      "birth",
      "cocoon",
      "plague",
      "spore",
      "blood-attach",
      "soul-drain",
      "infection",
      "infection-burst",
      "trap-spring",
      "advanced-birth"
    ],
    "source": "DungeonSim.effects",
    "renderer": "DungeonRenderer.renderEffects"
  },
  "packs": [
    {
      "id": "custom-dungeon-v1",
      "name": "Procedural port-connected dungeon kit",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/engine/"
    },
    {
      "id": "custom-miniatures-v6",
      "name": "Procedural modular miniatures equipment and faction ecology species",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/miniatures/"
    },
    {
      "id": "custom-ecology-v2",
      "name": "Procedural lairs corpses infections traps territories and spawn omens",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/engine/"
    },
    {
      "id": "custom-glb-parts",
      "name": "Future authored environment miniature equipment and ecology GLB parts",
      "status": "planned",
      "license": "Project-owned or explicitly licensed assets only",
      "target": "assets/models/"
    }

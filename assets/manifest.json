{
  "version": 5,
  "mode": "procedural-modular-dungeon-ecology",
  "notes": "Rooms, ports, facilities, combat, equipment and monster ecology are generated from shared runtime contracts. Species lairs, corpses, living hosts and staged births remain visible world entities.",
  "topology": {
    "builder": "src/engine/DungeonTopology.js",
    "connectionModel": "room-port to room-port",
    "movement": "continuous corridor and reserved-cell travel",
    "surfaceRule": "room floors and corridor floors share the same top-surface elevation"
  },
  "environment": {
    "factory": "src/engine/AssetRegistry.js",
    "activeAssets": [
      "room-floor-slab",
      "inset-room-floor",
      "segmented-wall",
      "door-frame",
      "door-threshold",
      "corridor-floor",
      "corridor-curbs",
      "entrance-waystation",
      "water-fountain",
      "rest-site",
      "camp-site",
      "merchant-stall",
      "goddess-statue"
    ]
  },
  "miniatures": {
    "recipes": "src/miniatures/recipes.js",
    "partCatalog": "src/miniatures/partCatalog.js",
    "factory": "src/engine/MiniatureFactory.js",
    "ecologyFactory": "src/engine/EcologyAssetFactory.js",
    "roles": [
      "fighter",
      "rogue",
      "cleric",
      "wizard",
      "archer",
      "goblin",
      "skeleton",
      "spider",
      "rat",
      "ogre",
      "slime",
      "mimic"
    ],
    "sharedSockets": [
      "root",
      "pelvis",
      "chest",
      "head",
      "headTop",
      "handL",
      "handR",
      "shoulderL",
      "shoulderR",
      "back",
      "waistFront",
      "waistBack",
      "baseFx"
    ]
  },
  "combat": {
    "simulation": "src/sim/DungeonSimPhase3.js",
    "projectiles": "src/sim/ProjectileSystem.js",
    "renderer": "src/engine/DungeonRendererPhase3.js",
    "activeProjectiles": ["arrow", "magic", "heal", "web"]
  },
  "equipment": {
    "catalog": "src/data/itemCatalog.js",
    "system": "src/sim/EquipmentSystem.js",
    "simulation": "src/sim/DungeonSimPhase4.js",
    "assetFactory": "src/engine/EquipmentAssetFactory.js",
    "renderer": "src/engine/DungeonRendererPhase4.js",
    "slots": ["mainHand", "offHand", "head", "body", "accessory"],
    "features": [
      "role-aware automatic equipment comparison",
      "monster and treasure loot tables",
      "floor loot dioramas",
      "weapon and armor durability",
      "equipment break and repair",
      "merchant buy sell and repair",
      "live miniature socket replacement"
    ]
  },
  "ecology": {
    "scenarioDecorator": "src/data/applyPhase5Ecology.js",
    "system": "src/sim/EcosystemSystem.js",
    "simulation": "src/sim/DungeonSimPhase5.js",
    "assetFactory": "src/engine/EcologyAssetFactory.js",
    "renderer": "src/engine/DungeonRendererPhase5.js",
    "species": ["skeleton", "goblin", "spider", "slime", "rat", "ogre"],
    "lairs": ["ossuary_lair", "goblin_lair", "spider_lair", "slime_pool", "rat_warren", "ogre_lair"],
    "worldEntities": ["corpse", "living_host", "pending_spawn"],
    "features": [
      "species hunger and starvation",
      "intra-dungeon predation",
      "corpse biomass and bone resources",
      "spider host capture and transport",
      "resource-gated reproduction",
      "visible timed spawn omens",
      "lair footprint occupancy blocking"
    ]
  },
  "effects": {
    "active": [
      "attack",
      "death",
      "gold",
      "heal",
      "arrow-impact",
      "magic-impact",
      "web-impact",
      "downed",
      "equipment-upgrade",
      "equipment-break",
      "feeding",
      "birth",
      "cocoon"
    ],
    "source": "DungeonSim.effects",
    "renderer": "DungeonRenderer.renderEffects"
  },
  "packs": [
    {
      "id": "custom-dungeon-v1",
      "name": "Procedural port-connected dungeon kit",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/engine/"
    },
    {
      "id": "custom-miniatures-v5",
      "name": "Procedural modular miniatures equipment and ecology species",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/miniatures/"
    },
    {
      "id": "custom-ecology-v1",
      "name": "Procedural species lairs corpses cocoons and spawn omens",
      "status": "active",
      "license": "Original project code and generated geometry",
      "target": "src/engine/EcologyAssetFactory.js"
    },
    {
      "id": "custom-glb-parts",
      "name": "Future authored environment miniature equipment and ecology GLB parts",
      "status": "planned",
      "license": "Project-owned or explicitly licensed assets only",
      "target": "assets/models/"
    }
  ],
  "modelSlots": {
    "rooms": {
      "floor": "procedural:room-floor-slab",
      "wall": "procedural:segmented-wall",
      "door": "procedural:door-frame",
      "corridor": "procedural:corridor-floor"
    },
    "props": {
      "chest": "procedural:chest",
      "trap": "procedural:trap",
      "armory": "procedural:armory",
      "shrine": "procedural:shrine",
      "loot": "procedural:equipment-loot-pile",
      "goblin_lair": "procedural:goblin-hearth-lair",
      "ossuary_lair": "procedural:working-ossuary",
      "spider_lair": "procedural:silk-brood-chamber",
      "slime_pool": "procedural:digestive-spawning-pool",
      "rat_warren": "procedural:granary-rat-warren",
      "ogre_lair": "procedural:ogre-butcher-camp"
    },
    "agents": {
      "fighter": "recipe:fighter_rana_v1",
      "rogue": "recipe:rogue_milo_v1",
      "cleric": "recipe:cleric_pell_v1",
      "wizard": "recipe:wizard_orwin_v1",
      "archer": "recipe:archer_alda_v1",
      "goblin": "recipe:goblin_common_v1",
      "skeleton": "recipe:skeleton_common_v1",
      "spider": "procedural:ecology-spider",
      "rat": "procedural:ecology-rat",
      "ogre": "recipe:ogre_large_v1",
      "slime": "recipe:slime_common_v1",
      "mimic": "recipe:mimic_common_v1"
    }
  }
}

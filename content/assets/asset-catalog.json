{
  "$schema": "../schemas/asset-catalog.schema.json",
  "schemaVersion": 1,
  "catalogVersion": "0.1.0",
  "status": "design-complete-runtime-pending",
  "resolverOrder": ["authored", "proceduralFallback", "primitiveFallback", "diagnosticMarker"],
  "roots": {
    "models": "assets/models/",
    "textures": "assets/textures/",
    "audio": "assets/audio/",
    "ui": "assets/ui/",
    "licenses": "assets/licenses/"
  },
  "licensePolicy": {
    "externalAssetsRequireLicenseEntry": true,
    "hotlinkingAllowed": false,
    "preferredLicenses": ["CC0", "project-owned"],
    "licenseFileConvention": "assets/licenses/<pack-id>/LICENSE.txt"
  },
  "conventions": {
    "worldUp": "Y",
    "forward": "+Z",
    "unitMeters": 1,
    "roomSurfaceY": 0,
    "characterSocketContract": ["root", "pelvis", "chest", "head", "headTop", "handL", "handR", "shoulderL", "shoulderR", "back", "waistFront", "waistBack", "baseFx"],
    "requiredVariants": ["default", "damaged"],
    "recommendedVariants": ["occupied", "ruined", "burned", "infested"]
  },
  "performanceBudgets": {
    "desktopHeroDioramaTriangles": 75000,
    "mobileHeroDioramaTriangles": 28000,
    "desktopRoomKitTextureSize": 2048,
    "mobileRoomKitTextureSize": 1024,
    "maximumDynamicLightsPerVisibleRoom": 3,
    "maximumParticlesPerVisibleRoomMobile": 80
  },
  "templates": {
    "zone-kit": {
      "kind": "environment-kit",
      "proceduralFallback": { "factory": "CampaignZoneFallbackFactory", "recipeFromId": true },
      "primitiveFallback": "diagnostic.room-kit"
    },
    "campaign-landmark": {
      "kind": "diorama",
      "proceduralFallback": { "factory": "CampaignLandmarkFallbackFactory", "recipeFromId": true },
      "primitiveFallback": "diagnostic.landmark",
      "defaultFootprint": { "radius": 1.8 }
    },
    "facility": {
      "kind": "diorama",
      "proceduralFallback": { "factory": "FacilityAssetFactory", "recipeFromId": true },
      "primitiveFallback": "diagnostic.facility"
    },
    "settlement-structure": {
      "kind": "destructible-diorama",
      "proceduralFallback": { "factory": "Phase8DAssetFactory", "recipeFromId": true },
      "primitiveFallback": "diagnostic.structure"
    }
  },

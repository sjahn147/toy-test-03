{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "campaign.manifest",
  "description": "content/campaigns/<campaign>/campaign.manifest.json 구조. src/content/ContentValidator.js가 소비하므로 type/required/properties/items/enum 키워드만 사용합니다.",
  "type": "object",
  "required": [
    "schemaVersion",
    "contentVersion",
    "id",
    "name",
    "entranceRoomId",
    "zones",
    "rooms",
    "connections",
    "factions"
  ],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "contentVersion": { "type": "string" },
    "id": { "type": "string", "description": "campaign.<slug>" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "entranceRoomId": { "type": "string", "description": "room.<campaign-slug>.<zone-slug>.<slug>" },
    "layout": {
      "type": "object",
      "properties": {
        "gutter": { "type": "number" },
        "zoneGap": { "type": "number" }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "code", "name", "grid"],
        "properties": {
          "id": { "type": "string", "description": "zone.<campaign-slug>.<slug>" },
          "code": { "type": "string", "description": "구역 문자 코드 (A~M)" },
          "name": { "type": "string" },
          "grid": {
            "type": "object",
            "required": ["col", "row"],
            "properties": {
              "col": { "type": "integer" },
              "row": { "type": "integer" }
            }
          },
          "kit": { "type": "string", "description": "asset catalog의 kit.* bundle ID" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "code", "zoneId", "name", "size", "kind", "tags"],
        "properties": {
          "id": { "type": "string", "description": "room.<campaign-slug>.<zone-slug>.<slug>" },
          "code": { "type": "string", "description": "room bible 코드 (A01, B08 등)" },
          "zoneId": { "type": "string" },
          "name": { "type": "string" },
          "size": {
            "type": "object",
            "required": ["w", "d"],
            "properties": {
              "w": { "type": "number" },
              "d": { "type": "number" }
            },
            "description": "post-scale 단위 (Phase8 spatial scale 이미 적용된 값)"
          },
          "kind": {
            "type": "string",
            "enum": [
              "start",
              "hall",
              "gate",
              "pantry",
              "armory",
              "nest",
              "trap",
              "hatchery",
              "shrine",
              "treasure",
              "lair",
              "crypt"
            ],
            "description": "레거시 시나리오 room kind"
          },
          "tags": { "type": "array", "items": { "type": "string" } },
          "functions": { "type": "array", "items": { "type": "string" } },
          "propBundles": { "type": "array", "items": { "type": "string" } },
          "stateVariants": { "type": "array", "items": { "type": "string" } },
          "danger": { "type": "number" },
          "spawnWeight": { "type": "number" },
          "layoutHint": {
            "type": "object",
            "properties": {
              "dx": { "type": "number" },
              "dz": { "type": "number" }
            },
            "description": "존 내부 shelf-packing에 대한 선택적 오프셋 힌트"
          },
          "settlementCandidate": {
            "type": "object",
            "required": ["scale", "capacity"],
            "properties": {
              "scale": { "type": "string", "enum": ["small", "medium", "large"] },
              "capacity": { "type": "integer" }
            }
          }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string", "enum": ["normal", "secret"] },
          "discovery": { "type": "string", "description": "secret connection의 발견 조건 (예: hidden)" },
          "note": { "type": "string" }
        }
      }
    },
    "factions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "legacyEcologyFaction", "homeRoomId", "startingAgents"],
        "properties": {
          "id": { "type": "string", "description": "faction.<campaign-slug>.<slug>" },
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["party", "ecology"] },
          "species": { "type": "string", "description": "ecology 세력만 사용" },
          "legacyEcologyFaction": { "type": "string", "description": "기존 ecologyFaction ID 매핑" },
          "homeRoomId": { "type": "string" },
          "lair": {
            "type": "object",
            "required": ["propType", "capacity"],
            "properties": {
              "propType": { "type": "string", "description": "레거시 lair prop type (goblin_lair 등)" },
              "assetBundle": { "type": "string" },
              "capacity": { "type": "integer" },
              "stocks": { "type": "object" }
            },
            "description": "ecology 세력의 서식지 prop 배치"
          },
          "startingAgents": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role"],
              "properties": {
                "id": { "type": "string" },
                "role": { "type": "string" },
                "name": { "type": "string" },
                "count": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "wildlife": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["species", "lairRoomId", "propType", "count"],
        "properties": {
          "species": { "type": "string" },
          "lairRoomId": { "type": "string" },
          "propType": { "type": "string" },
          "count": { "type": "integer" },
          "stocks": { "type": "object" }
        }
      }
    }
  }
}

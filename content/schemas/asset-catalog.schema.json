{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/the-little-dungeon/content/schemas/asset-catalog.schema.json",
  "title": "Dungeon ecosystem asset catalog",
  "type": "object",
  "required": [
    "schemaVersion",
    "catalogVersion",
    "resolverOrder",
    "roots",
    "templates",
    "entries",
    "coverage"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "resolverOrder": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["authored", "proceduralFallback", "primitiveFallback", "diagnosticMarker"]
      }
    },
    "roots": {
      "type": "object",
      "required": ["models", "textures", "audio", "ui", "licenses"],
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "licensePolicy": { "type": "object", "additionalProperties": true },
    "conventions": { "type": "object", "additionalProperties": true },
    "performanceBudgets": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } },
    "templates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/template" }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "coverage": {
      "type": "object",
      "required": ["campaignId", "expectedZoneKitCount", "expectedRoomLandmarkCount"],
      "properties": {
        "campaignId": { "type": "string", "minLength": 1 },
        "expectedZoneKitCount": { "type": "integer", "minimum": 0 },
        "expectedRoomLandmarkCount": { "type": "integer", "minimum": 0 },
        "innVerticalSliceIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "template": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "proceduralFallback": { "$ref": "#/$defs/fallback" },
        "primitiveFallback": { "type": "string", "minLength": 1 },
        "defaultFootprint": { "$ref": "#/$defs/footprint" }
      },
      "additionalProperties": true
    },
    "entry": {
      "type": "object",
      "required": ["id", "status", "priority"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "kind": { "type": "string", "minLength": 1 },
        "template": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["active-procedural", "reuse", "upgrade", "author", "content", "fallback", "planned", "ready"]
        },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "authored": { "$ref": "#/$defs/authored" },
        "proceduralFallback": { "$ref": "#/$defs/fallback" },
        "primitiveFallback": { "type": "string", "minLength": 1 },
        "footprint": { "$ref": "#/$defs/footprint" },
        "variants": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredIcons": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "loops": { "type": "boolean" }
      },
      "anyOf": [
        { "required": ["kind"] },
        { "required": ["template"] }
      ],
      "additionalProperties": true
    },
    "authored": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "model": { "type": "string", "pattern": "^assets/" },
        "root": { "type": "string", "pattern": "^assets/" },
        "image": { "type": "string", "pattern": "^assets/" },
        "metadata": { "type": "string", "pattern": "^assets/" },
        "audio": { "type": "string", "pattern": "^assets/" }
      },
      "additionalProperties": { "type": "string" }
    },
    "fallback": {
      "type": "object",
      "required": ["factory"],
      "properties": {
        "factory": { "type": "string", "minLength": 1 },
        "recipe": { "type": "string", "minLength": 1 },
        "recipeFromId": { "type": "boolean" }
      },
      "anyOf": [
        { "required": ["recipe"] },
        { "required": ["recipeFromId"] }
      ],
      "additionalProperties": true
    },
    "footprint": {
      "type": "object",
      "properties": {
        "shape": { "type": "string", "enum": ["circle", "box", "cells"] },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "depth": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": true
    }
  }
}

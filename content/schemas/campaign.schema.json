{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/the-little-dungeon/content/schemas/campaign.schema.json",
  "title": "Dungeon ecosystem campaign manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "contentVersion",
    "id",
    "title",
    "entryRoomId",
    "zones",
    "rooms",
    "connections",
    "factions",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "contentVersion": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "$ref": "#/$defs/localizedText"
    },
    "status": {
      "type": "string"
    },
    "entryRoomId": {
      "type": "string",
      "minLength": 1
    },
    "docs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "runtimeRequirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/zone"
      }
    },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/room"
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/roomPair"
      }
    },
    "conditionalConnections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conditionalConnection"
      }
    },
    "secretConnections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/secretConnection"
      }
    },
    "factions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/faction"
      }
    },
    "campaignMilestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      }
    },
    "globalEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/globalEvent"
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "expectedRoomCount",
        "requireLandmarkBundleForEveryRoom"
      ],
      "properties": {
        "expectedRoomCount": {
          "type": "integer",
          "minimum": 1
        },
        "minimumSecretConnections": {
          "type": "integer",
          "minimum": 0
        },
        "minimumSettlementCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "minimumLargeCreatureDoorWidth": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "requireLandmarkBundleForEveryRoom": {
          "type": "boolean"
        },
        "requireStateVariantsForEveryRoom": {
          "type": "boolean"
        },
        "allowRuntimeMissingAssetsDuringDesign": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "floors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/floor"
      }
    },
    "verticalConnectors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verticalConnector"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "localizedText": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "zone": {
      "type": "object",
      "required": [
        "id",
        "name",
        "zoneKit",
        "roomIds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9-]*$"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "zoneKit": {
          "type": "string",
          "minLength": 1
        },
        "roomIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "room": {
      "type": "object",
      "required": [
        "id",
        "zoneId",
        "name",
        "kind",
        "size",
        "tags",
        "landmarkBundle",
        "stateVariants"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][0-9]{2}$"
        },
        "zoneId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "minimum": 6
            },
            {
              "type": "number",
              "minimum": 6
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "tags": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "landmarkBundle": {
          "type": "string",
          "minLength": 1
        },
        "ambientBundles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stateVariants": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "floorId": {
          "type": "string",
          "enum": [
            "F0",
            "B1",
            "B2",
            "B3"
          ]
        },
        "floor": {
          "type": "integer",
          "minimum": -3,
          "maximum": 0
        }
      },
      "additionalProperties": true
    },
    "roomPair": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "conditionalConnection": {
      "type": "object",
      "required": [
        "id",
        "from",
        "to",
        "condition",
        "defaultState"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "defaultState": {
          "type": "string",
          "enum": [
            "locked",
            "open",
            "closed",
            "blocked"
          ]
        }
      },
      "additionalProperties": true
    },
    "secretConnection": {
      "type": "object",
      "required": [
        "id",
        "from",
        "to",
        "discovery"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "discovery": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "faction": {
      "type": "object",
      "required": [
        "id",
        "runtimeFactionId",
        "initialRooms",
        "goals"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "runtimeFactionId": {
          "type": "string",
          "minLength": 1
        },
        "initialRooms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "milestone": {
      "type": "object",
      "required": [
        "id",
        "requirements",
        "effects"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "globalEvent": {
      "type": "object",
      "required": [
        "id",
        "zones",
        "effects"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "floor": {
      "type": "object",
      "required": [
        "id",
        "index",
        "name",
        "roomIds"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "index": {
          "type": "integer"
        },
        "elevation": {
          "type": "number"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "roomIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "cameraProfile": {
          "type": "string"
        },
        "ambientProfile": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "landing": {
      "type": "object",
      "required": [
        "id",
        "floorId",
        "roomId",
        "position"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "connectorId": {
          "type": "string"
        },
        "floorId": {
          "type": "string"
        },
        "roomId": {
          "type": "string"
        },
        "position": {
          "type": "object",
          "required": [
            "x",
            "z"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "z": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "facing": {
          "type": "number"
        },
        "arrivalSocket": {
          "type": "object"
        },
        "queueSockets": {
          "type": "array"
        },
        "cameraAnchor": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "verticalConnector": {
      "type": "object",
      "required": [
        "id",
        "type",
        "state",
        "from",
        "to",
        "capacity"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "from": {
          "$ref": "#/$defs/landing"
        },
        "to": {
          "$ref": "#/$defs/landing"
        },
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "queueCapacity": {
          "type": "integer",
          "minimum": 1
        },
        "transitTime": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "allowsCargo": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string"
            }
          ]
        },
        "allowsLargeActors": {
          "type": "boolean"
        },
        "accessCondition": {
          "type": "string"
        },
        "visibility": {
          "type": "string"
        },
        "legacyRouteIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}

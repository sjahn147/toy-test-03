{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/the-little-dungeon/content/schemas/ui-surface.schema.json",
  "title": "Dungeon ecosystem production UI surface manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "contentVersion",
    "id",
    "layout",
    "surfaces",
    "selectionTypes",
    "overlaySelectors",
    "eventSeverities",
    "accessibility"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "contentVersion": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "description": { "type": "string" },
    "layout": {
      "type": "object",
      "required": ["desktop", "mobile"],
      "properties": {
        "desktop": { "$ref": "#/$defs/layoutMode" },
        "mobile": { "$ref": "#/$defs/mobileLayoutMode" }
      },
      "additionalProperties": true
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    },
    "selectionTypes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "overlaySelectors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^select[A-Z]" }
    },
    "eventSeverities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["ambient", "minor", "major", "critical", "historic"] }
    },
    "accessibility": {
      "type": "object",
      "required": [
        "minimumTouchTargetPx",
        "uiScaleRange",
        "supportsReducedMotion",
        "requiresTextLabelsForIcons",
        "requiresNonColorStateEncoding"
      ],
      "properties": {
        "minimumTouchTargetPx": { "type": "integer", "minimum": 44 },
        "uiScaleRange": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "exclusiveMinimum": 0 },
            { "type": "number", "exclusiveMinimum": 0 }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "supportsReducedMotion": { "type": "boolean" },
        "requiresTextLabelsForIcons": { "type": "boolean" },
        "requiresNonColorStateEncoding": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "layoutMode": {
      "type": "object",
      "required": ["regions"],
      "properties": {
        "regions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "collapsible": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "mobileLayoutMode": {
      "allOf": [
        { "$ref": "#/$defs/layoutMode" },
        {
          "type": "object",
          "properties": {
            "minimumViewportHeightRatio": { "type": "number", "minimum": 0.5, "maximum": 1 }
          }
        }
      ]
    },
    "surface": {
      "type": "object",
      "required": ["id", "region", "selectors", "commands"],
      "properties": {
        "id": { "type": "string", "pattern": "^surface\\.[a-z0-9._-]+$" },
        "region": { "type": "string", "minLength": 1 },
        "entityType": { "type": "string", "minLength": 1 },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^select[A-Z]" }
        },
        "commands": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z0-9-]+)+$" }
        },
        "priority": { "type": "string", "enum": ["persistent", "primary", "secondary", "contextual"] },
        "cards": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "filters": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "overlays": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "modes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    }
  }
}

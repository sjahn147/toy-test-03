{
  "name": "the-little-dungeon-that-could",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A tiny Three.js dungeon-observer web app with simple rule-driven agents.",
  "scripts": {
    "start": "python -m http.server 8000",
    "validate:production-content": "node tools/validate-production-content.mjs",
    "test:phase1": "node tests/phase1-smoke.mjs",
    "test:phase2": "node tests/phase2-smoke.mjs",
    "test:phase3": "node tests/phase3-combat-smoke.mjs",
    "test:phase4": "node tests/phase4-equipment-smoke.mjs",
    "test:phase5": "node tests/phase5-ecology-smoke.mjs",
    "test:phase6": "node tests/phase6-advanced-ecology-smoke.mjs",
    "test:phase7": "node tests/phase7-territory-smoke.mjs",
    "test:phase8": "node tests/phase8-settlement-smoke.mjs",
    "test:phase8b": "node tests/phase8b-expedition-smoke.mjs",
    "test:phase8c": "node tests/phase8c-logistics-spatial-smoke.mjs",
    "test:phase8d": "node tests/phase8d-construction-siege-smoke.mjs",
    "test:phase8e": "node tests/phase8e-personality-interaction-smoke.mjs",
    "test:content": "node tests/content-pipeline-smoke.mjs",
    "test:facade": "node tests/runtime-facade-smoke.mjs",
    "test:presentation": "node tests/presentation-boundary-smoke.mjs",
    "test:miniatures": "node tests/miniature-polish-smoke.mjs",
    "test:fungal": "node tests/fungal-garden-assets-smoke.mjs",
    "test:spider": "node tests/spider-colony-assets-smoke.mjs",
    "test:flooded": "node tests/p0-common-flooded-assets-smoke.mjs",
    "test:laboratory": "node tests/laboratory-assets-smoke.mjs",
    "test:royal": "node tests/royal-sanctum-assets-smoke.mjs",
    "test:asset-integration": "node tests/phase8-asset-resolver-smoke.mjs",
    "test:assets": "npm run test:miniatures && npm run test:fungal && npm run test:spider && npm run test:flooded && npm run test:laboratory && npm run test:royal && npm run test:asset-integration",
    "test:production": "npm run validate:production-content && npm run test:content && npm run test:facade && npm run test:presentation && npm run test:assets"
  },
  "keywords": ["threejs", "dungeon", "simulation", "agent-ai", "toy-game"]
}